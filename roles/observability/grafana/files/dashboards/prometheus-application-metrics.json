      "id": 13,
      "type": "timeseries",
      "title": "Deployment Spec Replicas",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 20,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (deployment) (kube_deployment_spec_replicas{namespace=\"mini-ecommerce\"})",
          "refId": "A",
          "legendFormat": "{{deployment}}"
