{
  "uid": "prometheus-application-metrics",
  "title": "Prometheus - Application Metrics",
  "tags": [
    "prometheus",
    "kubernetes",
    "metrics"
  ],
  "schemaVersion": 37,
  "version": 4,
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 3000,
      "type": "row",
      "title": "MINI-ECOMMERCE METRICS",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 3001,
      "type": "row",
      "title": "MINI-ECOMMERCE - TRAFFIC LAYER",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 3002,
      "type": "row",
      "title": "MINI-ECOMMERCE - DEGRADATION LAYER",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 3003,
      "type": "row",
      "title": "MINI-ECOMMERCE - STABILITY LAYER",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (RPS)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 2,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "(sum(irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\"}[15s])) ) or vector(0)",
          "refId": "A",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate per Service",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 2,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (service) (irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\"}[15s])) or on(service) (0 * max by (service) (up{job=\"mini-ecommerce-actuator\"}))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Rate per Namespace",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 16,
        "y": 2,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (namespace) (irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\"}[15s])) or on(namespace) (0 * max by (namespace) (up{job=\"mini-ecommerce-actuator\"}))",
          "refId": "A",
          "legendFormat": "{{namespace}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Drop Detection (offset 5m)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "(sum(irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\"}[15s])) - sum(irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\"}[15s] offset 5m))) or vector(0)",
          "refId": "A",
          "legendFormat": "delta"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Error Rate per Service (%)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "(100 * sum by (service) (irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\",status=~\"5..\"}[15s])) / clamp_min(sum by (service) (irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\"}[15s])), 0.001)) or on(service) (0 * max by (service) (up{job=\"mini-ecommerce-actuator\"}))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Error Spike per Service (5m)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 9,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (service) (irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\",status=~\"5..\"}[15s])) or on(service) (0 * max by (service) (up{job=\"mini-ecommerce-actuator\"}))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "P95 Latency per Service",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_server_requests_seconds_bucket{job=\"mini-ecommerce-actuator\"}[30s]))) or on(service) (0 * max by (service) (up{job=\"mini-ecommerce-actuator\"}))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Latency Violation Signal per Service",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "((histogram_quantile(0.95, sum by (le, service) (rate(http_server_requests_seconds_bucket{job=\"mini-ecommerce-actuator\"}[30s]))) > bool 0.5)) or on(service) (0 * max by (service) (up{job=\"mini-ecommerce-actuator\"}))",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Pod Restart (mini-ecommerce)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=\"mini-ecommerce\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Usage by Service",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 16,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "100 * avg by (service) (process_cpu_usage{job=\"mini-ecommerce-actuator\"})",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
