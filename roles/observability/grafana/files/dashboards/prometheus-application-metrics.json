    {
      "id": 14,
      "type": "timeseries",
      "title": "CPU Requests vs Limits",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 16,
        "y": 20,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (kube_pod_container_resource_requests{namespace=\"mini-ecommerce\",resource=\"cpu\",unit=\"core\"})",
          "refId": "A",
          "legendFormat": "{{namespace}}/{{pod}} requests"
        },
        {
          "expr": "sum by (namespace, pod) (kube_pod_container_resource_limits{namespace=\"mini-ecommerce\",resource=\"cpu\",unit=\"core\"})",
          "refId": "B",
          "legendFormat": "{{namespace}}/{{pod}} limits"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
