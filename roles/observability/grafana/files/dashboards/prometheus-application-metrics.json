    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Client RPS vs Server RPS",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(irate(http_server_requests_seconds_count{job=\"mini-ecommerce-actuator\",service=\"api-gateway\"}[15s])) or vector(0)",
          "refId": "A",
          "legendFormat": "server_rps_api_gateway"
        },
        {
          "expr": "sum(irate(k6_http_reqs[15s])) or vector(0)",
          "refId": "B",
          "legendFormat": "client_rps_k6"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
