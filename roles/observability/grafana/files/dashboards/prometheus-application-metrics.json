          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Usage by Service",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 16,
        "y": 16,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (service) (jvm_memory_used_bytes{job=\"mini-ecommerce-actuator\"})",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
