      "targets": [
        {
          "expr": "sum by (namespace, horizontalpodautoscaler) (kube_horizontalpodautoscaler_status_desired_replicas{namespace=~\"mini-ecommerce|argocd\"}) or vector(0)",
          "refId": "A",
          "legendFormat": "{{namespace}}/{{horizontalpodautoscaler}} Desired"
