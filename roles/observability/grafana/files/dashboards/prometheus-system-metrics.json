    {
      "id": 2121,
      "type": "timeseries",
      "title": "Pods Desired vs Ready (per Deployment, namespace=mini-ecommerce|argocd)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum by (namespace, deployment) (kube_deployment_spec_replicas{namespace=~\"mini-ecommerce|argocd\"})",
          "refId": "A",
          "legendFormat": "{{namespace}}/{{deployment}} Desired"
        },
        {
          "expr": "sum by (namespace, deployment) (kube_deployment_status_replicas_available{namespace=~\"mini-ecommerce|argocd\"})",
          "refId": "B",
          "legendFormat": "{{namespace}}/{{deployment}} Ready"
        }
      ],
