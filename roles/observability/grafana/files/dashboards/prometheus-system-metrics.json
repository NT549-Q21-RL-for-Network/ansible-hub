      "targets": [
        {
          "expr": "((sum by (service) (label_replace(max by (namespace,pod,container) (kube_pod_container_resource_requests{namespace=\"mini-ecommerce\",resource=\"memory\",unit=\"byte\"}), \"service\", \"$1\", \"pod\", \"^(.*?)(?:-[a-f0-9]{8,10}-[a-z0-9]{5}|-[0-9]+)?$\"))) / (1024^3)) or (0 * max by (service) (kube_service_info{namespace=\"mini-ecommerce\"}))",
          "refId": "A",
