{
  "uid": "prometheus-system-metrics",
  "title": "Prometheus - System Metrics",
  "tags": [
    "prometheus",
    "kubernetes",
    "metrics"
  ],
  "schemaVersion": 37,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 2000,
      "type": "row",
      "title": "SYSTEM METRICS",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2001,
      "type": "row",
      "title": "SYSTEM - HEALTH LAYER",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2002,
      "type": "row",
      "title": "SYSTEM - FAILURE SIGNAL LAYER",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2003,
      "type": "row",
      "title": "SYSTEM - RESOURCE PRESSURE LAYER",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 31,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Node Ready Ratio",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg(kube_node_status_condition{condition=\"Ready\",status=\"true\"}) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Nodes Not Ready",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 6,
        "y": 21,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"false\"})",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cluster CPU Utilization (%)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 21,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(node_cpu_seconds_total{mode!=\"idle\"}[5m])) / sum(rate(node_cpu_seconds_total[5m])) * 100",
          "refId": "A",
          "legendFormat": "cluster"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cluster Memory Utilization (%)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 18,
        "y": 21,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes) * 100",
          "refId": "A",
          "legendFormat": "cluster"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pod Restart by Namespace/Pod (5m)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (increase(kube_pod_container_status_restarts_total[5m]))",
          "refId": "A",
          "legendFormat": "{{namespace}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CrashLoopBackOff by Namespace/Pod",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (kube_pod_container_status_waiting_reason{reason=\"CrashLoopBackOff\"})",
          "refId": "A",
          "legendFormat": "{{namespace}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Deployment Replicas Unavailable",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 24,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (deployment) (kube_deployment_status_replicas_unavailable)",
          "refId": "A",
          "legendFormat": "{{deployment}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "CPU Pressure Ratio",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg((100 - avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))*100) > 80)",
          "refId": "A",
          "legendFormat": "ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Memory Pressure Ratio",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 32,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "avg(((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100) > 85)",
          "refId": "A",
          "legendFormat": "ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Usage per Pod",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 16,
        "y": 32,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{namespace!=\"\",pod!=\"\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{namespace}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Usage per Pod",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (container_memory_usage_bytes{namespace!=\"\",pod!=\"\"})",
          "refId": "A",
          "legendFormat": "{{namespace}}/{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
