    {
      "id": 2100,
      "type": "row",
      "title": "CPU Resource Overview",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2101,
      "type": "timeseries",
      "title": "CPU Usage by Namespace (System / App / Monitoring / ArgoCD)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 2,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum(max by (namespace,pod,container) (kube_pod_container_resource_requests{resource=\"cpu\",unit=\"core\",namespace!=\"\",namespace!~\"mini-ecommerce|observability|argocd\"}))",
          "refId": "A",
          "legendFormat": "System CPU (cores)"
        },
        {
          "expr": "sum(max by (namespace,pod,container) (kube_pod_container_resource_requests{resource=\"cpu\",unit=\"core\",namespace=\"mini-ecommerce\"}))",
          "refId": "B",
          "legendFormat": "App CPU (cores)"
        },
        {
          "expr": "(sum(max by (namespace,pod,container) (kube_pod_container_resource_requests{resource=\"cpu\",unit=\"core\",namespace=\"observability\"}))) or vector(0)",
          "refId": "C",
          "legendFormat": "Monitoring CPU (cores)"
        },
        {
          "expr": "(sum(max by (namespace,pod,container) (kube_pod_container_resource_requests{resource=\"cpu\",unit=\"core\",namespace=\"argocd\"}))) or vector(0)",
          "refId": "D",
          "legendFormat": "ArgoCD CPU (cores)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2102,
      "type": "timeseries",
      "title": "CPU Usage per Node (%)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 2,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "A",
          "legendFormat": "{{instance}} CPU (%)"
        },
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "B",
          "legendFormat": "Cluster Avg CPU (%)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2103,
      "type": "timeseries",
      "title": "CPU Usage per Service (mini-ecommerce)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 16,
        "y": 2,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "(sum by (service) (label_replace(max by (namespace,pod,container) (kube_pod_container_resource_requests{namespace=\"mini-ecommerce\",resource=\"cpu\",unit=\"core\"}), \"service\", \"$1\", \"pod\", \"^(.*?)(?:-[a-f0-9]{8,10}-[a-z0-9]{5}|-[0-9]+)?$\"))) or (0 * max by (service) (kube_service_info{namespace=\"mini-ecommerce\"}))",
          "refId": "A",
          "legendFormat": "{{service}} (cores)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
