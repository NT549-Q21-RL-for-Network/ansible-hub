    },
    {
      "id": 2110,
      "type": "row",
      "title": "Memory Resource Overview",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2111,
      "type": "timeseries",
      "title": "Memory Usage by Namespace (System / App / Monitoring / ArgoCD)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "sum(max by (namespace,pod,container) (kube_pod_container_resource_requests{resource=\"memory\",unit=\"byte\",namespace!=\"\",namespace!~\"mini-ecommerce|observability|argocd\"})) / (1024^3)",
          "refId": "A",
          "legendFormat": "System RAM (GiB)"
        },
        {
          "expr": "sum(max by (namespace,pod,container) (kube_pod_container_resource_requests{resource=\"memory\",unit=\"byte\",namespace=\"mini-ecommerce\"})) / (1024^3)",
          "refId": "B",
          "legendFormat": "App RAM (GiB)"
        },
        {
          "expr": "((sum(max by (namespace,pod,container) (kube_pod_container_resource_requests{resource=\"memory\",unit=\"byte\",namespace=\"observability\"}))) / (1024^3)) or vector(0)",
          "refId": "C",
          "legendFormat": "Monitoring RAM (GiB)"
        },
        {
          "expr": "((sum(max by (namespace,pod,container) (kube_pod_container_resource_requests{resource=\"memory\",unit=\"byte\",namespace=\"argocd\"}))) / (1024^3)) or vector(0)",
          "refId": "D",
          "legendFormat": "ArgoCD RAM (GiB)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2112,
      "type": "timeseries",
      "title": "Memory Usage per Node (GiB)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / (1024^3)",
          "refId": "A",
          "legendFormat": "{{instance}} RAM (GiB)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
