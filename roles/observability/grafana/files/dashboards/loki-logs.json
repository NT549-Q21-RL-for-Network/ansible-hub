{
  "uid": "loki-logs",
  "title": "Loki - System & Application Logs",
  "tags": ["loki", "kubernetes", "logs"],
  "schemaVersion": 37,
  "version": 1,
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Logs",
      "datasource": "Loki",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\".+\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "System Logs",
      "datasource": "Loki",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "App Logs (mini-ecommerce)",
      "datasource": "Loki",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\"mini-ecommerce.*\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Errors",
      "datasource": "Loki",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\".+\"} |= \"error\" [$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Warnings",
      "datasource": "Loki",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\".+\"} |= \"warn\" [$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Infos",
      "datasource": "Loki",
      "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(count_over_time({namespace=~\".+\"} |= \"info\" [$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "System Log Volume (by Namespace)",
      "datasource": "Loki",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"}[$__interval]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Application Log Volume (mini-ecommerce)",
      "datasource": "Loki",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 6},
      "targets": [
        {
          "expr": "sum by (namespace) (count_over_time({namespace=~\"mini-ecommerce.*\"}[$__interval]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "System Logs",
      "datasource": "Loki",
      "gridPos": {"x": 0, "y": 10, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "{namespace=~\"kube-system|monitoring|kube-public|kube-node-lease\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Application Logs (mini-ecommerce)",
      "datasource": "Loki",
      "gridPos": {"x": 12, "y": 10, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "{namespace=~\"mini-ecommerce.*\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    }
  ]
}
