server {
    listen {{ tempo_otlp_http_compat_proxy_port }};
    server_name _;

    access_log /var/log/nginx/tempo-otlp-compat.access.log;
    error_log /var/log/nginx/tempo-otlp-compat.error.log;

    client_max_body_size 16m;

    location = / {
        proxy_pass http://127.0.0.1:{{ tempo_otlp_http_port }}/v1/traces;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:{{ tempo_otlp_http_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
