# =====================================================
# Observability Inventory - Dev (KVM) (Example)
# Nodes for Prometheus, Grafana, Loki, Tempo
# =====================================================

[monitoring]
obser-1 ansible_host=192.168.201.20 ansible_user=ubuntu ansible_ssh_private_key_file=<SSH_PRIVATE_KEY_PATH>

[logging]
obser-2 ansible_host=192.168.201.21 ansible_user=ubuntu ansible_ssh_private_key_file=<SSH_PRIVATE_KEY_PATH>

[all:vars]
loki_host=192.168.201.21
tempo_host=192.168.201.21
